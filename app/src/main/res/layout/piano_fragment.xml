<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="16dp">

    <Button
        android:id="@+id/botonDo"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="DO"/>

    <Button
        android:id="@+id/botonRe"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="RE"/>

    <Button
        android:id="@+id/botonMi"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="MI"/>

    <Button
        android:id="@+id/botonFa"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="FA"/>

    <Button
        android:id="@+id/botonSol"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="SOL"/>

    <Button
        android:id="@+id/botonLa"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="LA"/>

    <Button
        android:id="@+id/botonSi"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="SI"/>

    <Button
        android:id="@+id/botonDo2"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="DO"/>

</LinearLayout>